# === フォント ===
font-family = "Ubuntu Mono"
font-size = 13

# === 背景・前景 ===
# Ubuntu名物のアバジン（暗い紫）
background = #300A24
# === Tangoカラーパレット（GNOME Terminalのデフォルト） ===
# 通常色 0-7
palette = 0=#2E3436
palette = 1=#CC0000
palette = 2=#4E9A06
palette = 3=#C4A000
palette = 4=#3465A4
palette = 5=#75507B
palette = 6=#06989A
palette = 7=#D3D7CF
# 明色 8-15
palette = 8=#555753
palette = 9=#EF2929
palette = 10=#8AE234
palette = 11=#FCE94F
palette = 12=#729FCF
palette = 13=#AD7FA8
palette = 14=#34E2E2
palette = 15=#EEEEEC

# === カーソル ===
cursor-style = block
cursor-style-blink = true
cursor-color = #FFFFFF

# === 選択色（GNOME Terminalデフォルトに近い反転表示） ===
selection-background = #B5D5FF
selection-foreground = #000000

# === ウィンドウサイズ（80x24がGNOME Terminalのデフォルト） ===
window-width = 80
window-height = 24

# === 余白を控えめに（GNOME Terminalは内側パディングが小さい） ===
window-padding-x = 2
window-padding-y = 2
window-padding-balance = true
