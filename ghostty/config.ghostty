# Ghostty の設定ファイル
# === フォント ===
font-family = "JetBrainsMono Nerd Font"
font-size = 14

# === 背景・前景（Catppuccin Mocha） ===
background = #1e1e2e
foreground = #cdd6f4

# === カーソル ===
cursor-style = block
cursor-style-blink = true
cursor-color = #f5e0dc

# === 選択色 ===
selection-background = #585b70
selection-foreground = #cdd6f4

# === カラーパレット（Catppuccin Mocha） ===
# 通常色 0-7
palette = 0=#45475a
palette = 1=#f38ba8
palette = 2=#a6e3a1
palette = 3=#f9e2af
palette = 4=#89b4fa
palette = 5=#f5c2e7
palette = 6=#94e2d5
palette = 7=#bac2de
# 明色 8-15
palette = 8=#585b70
palette = 9=#f38ba8
palette = 10=#a6e3a1
palette = 11=#f9e2af
palette = 12=#89b4fa
palette = 13=#cba6f7
palette = 14=#94e2d5
palette = 15=#a6adc8

# === ウィンドウ ===
window-width = 80
window-height = 24
window-padding-x = 6
window-padding-y = 4
window-padding-balance = true

# === 半透明 ===
background-opacity = 0.75
